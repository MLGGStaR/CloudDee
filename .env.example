# Copy this to .env and fill in. Never commit .env.

# ---- AI providers (REQUIRED) ----
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ---- Source data (free, but require sign-up) ----
COURTLISTENER_API_TOKEN=                # https://www.courtlistener.com/help/api/rest/
PEXELS_API_KEY=                         # https://www.pexels.com/api/  (free, no card)

# ---- YouTube (REQUIRED for upload) ----
# One set per channel. The pipeline reads YT_CHANNELS_JSON if present, otherwise these.
# Get these by following SETUP.md "YouTube OAuth" section.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JSON-encoded mapping of channel slug → refresh token.
# Example: {"final-approach":"1//0g...","verdict-files":"1//0h..."}
YT_REFRESH_TOKENS_JSON={}

# ---- Pipeline behavior ----
DOCKET_DB_PATH=docket.db
DOCKET_OUTPUT_DIR=output
DOCKET_DRY_RUN=0                        # 1 = produce video but skip YouTube upload
DOCKET_MAX_VIDEOS_PER_RUN=3             # Safety cap so one bad day can't drain $$$
DOCKET_LOG_LEVEL=INFO

# ---- Optional ----
DOCKET_TIMEZONE=America/New_York        # For scheduling readability in logs
